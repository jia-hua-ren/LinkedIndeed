{
  "manifest_version": 3,
  "name": "Linked, Indeed!",
  "version": "1.0.0",
  "description": "Linked, Indeed! — save job listings with clean URLs and extracted details from Indeed, LinkedIn, and more.",
  "permissions": ["activeTab", "storage", "clipboardWrite"],
  "host_permissions": [
    "https://www.indeed.com/viewjob*",
    "https://www.linkedin.com/jobs/view/*",
    "https://job-boards.greenhouse.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.indeed.com/viewjob*",
        "https://www.linkedin.com/jobs/view/*",
        "https://job-boards.greenhouse.io/*"
      ],
      "js": ["jobsites/linkedin.js", "jobsites/greenhouse.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
